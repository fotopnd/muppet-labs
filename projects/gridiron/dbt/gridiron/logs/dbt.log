  create view "gridiron"."public_staging"."stg_player_game_stats__dbt_tmp"
    
    
  as (
    select
    id,
    game_id,
    player_id,
    program_id,
    -- passing
    pass_attempts,
    pass_completions,
    pass_yards,
    pass_tds,
    interceptions,
    -- rushing
    rush_attempts,
    rush_yards,
    rush_tds,
    -- receiving
    targets,
    receptions,
    receiving_yards,
    receiving_tds,
    -- defense
    tackles,
    sacks,
    forced_fumbles,
    ints_def,
    -- special teams
    fg_attempts,
    fg_made,
    -- derived
    case when pass_attempts > 0
        then round((pass_completions::numeric / pass_attempts) * 100, 1)
    end as completion_pct,
    case when fg_attempts > 0
        then round((fg_made::numeric / fg_attempts) * 100, 1)
    end as fg_pct
from "gridiron"."public"."player_game_stats"
  );
