# Case Queue API
REVIEWER_API_URL=http://localhost:8000
REVIEWER_ACTOR_ID=ai-reviewer
REVIEWER_ACTOR_ROLE=senior_reviewer

# LLM backend: "ollama" (free, local) or "claude" (paid, better quality)
REVIEWER_BACKEND=ollama

# Claude settings (only used when REVIEWER_BACKEND=claude)
ANTHROPIC_API_KEY=sk-ant-...
REVIEWER_CLAUDE_MODEL=claude-haiku-4-5-20251001
REVIEWER_CLAUDE_MAX_CASES=10        # hard cap per poll cycle; raise with caution

# Ollama settings (only used when REVIEWER_BACKEND=ollama)
REVIEWER_OLLAMA_BASE_URL=http://localhost:11434/v1
REVIEWER_OLLAMA_MODEL=gemma2:9b

# Behaviour
REVIEWER_CONFIDENCE_THRESHOLD=0.80  # below this → escalate
REVIEWER_POLL_INTERVAL=30           # seconds between polls
REVIEWER_BATCH_SIZE=10              # cases fetched per poll cycle
