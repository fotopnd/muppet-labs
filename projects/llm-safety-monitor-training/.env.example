# HuggingFace token for dataset access
HF_TOKEN=hf_your_token_here

# Output paths for training (absolute paths to workspace resources/models/)
PAIR_CLASSIFIER_OUT=/path/to/resources/models/llm-safety-monitor/pair-classifier
PROMPT_DETECTOR_OUT=/path/to/resources/models/llm-safety-monitor/prompt-detector
TAXONOMY_CLASSIFIER_OUT=/path/to/resources/models/llm-safety-monitor/taxonomy-classifier

# Output path for eval JSONs
EVAL_OUT=/path/to/resources/evals/llm-safety-monitor
