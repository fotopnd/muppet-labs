# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC=moderation-events
KAFKA_NUM_PARTITIONS=5

# Postgres (port 5434 — separate from case-queue on 5432 and moderation-stream on 5433)
POSTGRES_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5434/moderation_dashboard
POSTGRES_URL_ASYNC=postgresql+asyncpg://postgres:postgres@localhost:5434/moderation_dashboard

# Producer
JIGSAW_CSV_PATH=/path/to/resources/datasets/jigsaw-toxic-comments/train.csv
PRODUCER_RATE_PER_SEC=10.0

# API
CORS_ORIGINS=["http://localhost:5174"]

# Escalation
CASE_QUEUE_API_URL=http://localhost:8000
ESCALATION_CONFIDENCE_THRESHOLD=0.6
ESCALATION_POLL_INTERVAL_SECS=10.0

# Anomaly detection
ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_WINDOW_MINUTES=5
ANOMALY_MIN_HISTORY_WINDOWS=10

# dbt
DBT_PROJECT_DIR=/path/to/projects/moderation-dashboard/dbt
DBT_DB_HOST=localhost
DBT_DB_PORT=5434
DBT_DB_USER=postgres
DBT_DB_PASSWORD=postgres
DBT_DB_NAME=moderation_dashboard

# Fine-tuned model checkpoints — set after training
# DISTILBERT_CHECKPOINT_PATH=/path/to/resources/models/toxicity-classifier-finetuned/distilbert-best

# Demo config
# On local dev, all three zero-shot models are live. On VPS, only distilbert and detoxify run.
# LIVE_MODELS=["distilbert","detoxify"]
SPARKLINE_WINDOW_SIZE=50
