# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/llm_safety_monitor
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5434/llm_safety_monitor

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=llm-interactions

# Model checkpoints (absolute paths to workspace resources/models/)
PAIR_CLASSIFIER_PATH=/path/to/resources/models/llm-safety-monitor/pair-classifier
PROMPT_DETECTOR_PATH=/path/to/resources/models/llm-safety-monitor/prompt-detector
TAXONOMY_CLASSIFIER_PATH=/path/to/resources/models/llm-safety-monitor/taxonomy-classifier

# Replay producer dataset mix (must sum to 1.0)
REPLAY_MIX_HHRLHF=0.60
REPLAY_MIX_WILDGUARD=0.25
REPLAY_MIX_ADVBENCH=0.10
REPLAY_MIX_JAILBREAKBENCH=0.05

# Case-queue integration
CASE_QUEUE_URL=http://localhost:8000

# Optional: live Claude API mode (off by default)
LIVE_CLAUDE_MODE=false
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API server
API_HOST=0.0.0.0
API_PORT=8002
